{
    "name": "mini-trainer-engine",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:daz": "VITE_APP_ID=daz vite",
        "dev:math": "VITE_APP_ID=mathematik vite",
        "dev:deutsch": "VITE_APP_ID=deutsch vite",
        "dev:sachunterricht": "VITE_APP_ID=sachunterricht vite",
        "dev:musik": "VITE_APP_ID=musik vite",
        "dev:kunst": "VITE_APP_ID=kunst vite",
        "dev:technik": "VITE_APP_ID=technik vite",
        "dev:englisch": "VITE_APP_ID=englisch vite",
        "build": "node scripts/build-app.mjs --app daz",
        "build:daz": "node scripts/build-app.mjs --app daz",
        "build:daz:pwa": "node scripts/build-app.mjs --app daz --pwa",
        "build:math": "node scripts/build-app.mjs --app mathematik",
        "build:math:pwa": "node scripts/build-app.mjs --app mathematik --pwa",
        "build:deutsch": "node scripts/build-app.mjs --app deutsch",
        "build:deutsch:pwa": "node scripts/build-app.mjs --app deutsch --pwa",
        "build:sachunterricht": "node scripts/build-app.mjs --app sachunterricht",
        "build:sachunterricht:pwa": "node scripts/build-app.mjs --app sachunterricht --pwa",
        "build:musik": "node scripts/build-app.mjs --app musik",
        "build:musik:pwa": "node scripts/build-app.mjs --app musik --pwa",
        "build:kunst": "node scripts/build-app.mjs --app kunst",
        "build:kunst:pwa": "node scripts/build-app.mjs --app kunst --pwa",
        "build:technik": "node scripts/build-app.mjs --app technik",
        "build:technik:pwa": "node scripts/build-app.mjs --app technik --pwa",
        "build:englisch": "node scripts/build-app.mjs --app englisch",
        "build:englisch:pwa": "node scripts/build-app.mjs --app englisch --pwa",
        "build:all": "node scripts/build-all-apps.mjs --both",
        "build:all:usb": "node scripts/build-all-apps.mjs",
        "build:all:pwa": "node scripts/build-all-apps.mjs --pwa",
        "preview": "vite preview",
        "preview:math": "vite preview --outDir dist/mathematik --base ./",
        "preview:daz": "vite preview --outDir dist/daz --base ./",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc --noEmit",
        "validate": "node scripts/validate-config.mjs",
        "add-exercise": "node scripts/add-exercise.mjs",
        "clean": "rm -rf dist node_modules/.vite"
    },
    "dependencies": {
        "autoprefixer": "^10.4.24",
        "class-variance-authority": "^0.7.1",
        "i18next": "^24.2.2",
        "idb": "^8.0.1",
        "postcss": "^8.5.6",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-i18next": "^15.4.0",
        "react-router-dom": "^6.28.2",
        "tailwindcss": "^3.4.17",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.1.0",
        "@types/node": "^25.2.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.55.0",
        "@typescript-eslint/parser": "^8.55.0",
        "@vitejs/plugin-react": "^4.3.4",
        "@vitest/coverage-v8": "^2.1.9",
        "eslint": "^9.39.2",
        "jsdom": "^28.1.0",
        "typescript": "^5.6.3",
        "vite": "^6.0.5",
        "vitest": "^2.1.8"
    }
}
